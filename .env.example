# ---- Cast ASP env template. Copy to .env and fill. NEVER commit real values. ----

# fal.ai (FLUX Kontext) — https://fal.ai/dashboard/keys
FAL_KEY=

# X Layer
XLAYER_RPC=https://xlayerrpc.okx.com
# Payment network: eip155:196 (mainnet) or eip155:1952 (testnet — free, use for dev)
X402_NETWORK=eip155:196
# Testnet RPC (when X402_NETWORK=eip155:1952): https://testrpc.xlayer.tech/terigon
# Testnet faucet (OKB gas + test tokens): https://web3.okx.com/xlayer/faucet
PASSPORT_CONTRACT=            # deployed CharacterPassport address (see README)
SIGNER_PK=                    # relayer key that mints passports + pays X Layer gas (0x...)
PAY_TO=                       # your Agentic Wallet address — receives USDT0

# OKX x402 facilitator auth (from OKX Web3 developer console / API mgmt)
# The SDK's OKXFacilitatorClient uses these; there is NO facilitator URL to set.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# server
PORT=4000

# NOTE: settlement token USDT0 (0x779Ded...3736, 6 decimals) on X Layer eip155:196
# is AUTO-CONFIGURED by the SDK — do not add it here.
